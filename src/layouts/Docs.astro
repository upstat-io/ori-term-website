---
import Base from './Base.astro';
import Nav from '../components/Nav.svelte';
import TableOfContents from '../components/TableOfContents.svelte';
import Footer from '../components/Footer.svelte';

interface TocEntry {
  id: string;
  text: string;
  level: number;
}

interface Props {
  title: string;
  description?: string;
  toc: TocEntry[];
}

const { title, description, toc } = Astro.props;
---

<Base title={`${title} — ori-term`} description={description}>
  <Nav client:load />

  <div class="docs-layout">
    <aside class="docs-sidebar">
      <TableOfContents entries={toc} client:load />
    </aside>
    <main class="docs-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">home</a> / <a href="/docs">docs</a> / <span class="current">{title.toLowerCase()}</span>
      </nav>
      <h1 class="docs-title">{title}</h1>
      <slot />
    </main>
  </div>

  <Footer client:load />
</Base>

<style>
  .docs-layout {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px var(--gutter) 120px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }

  .docs-sidebar {
    display: block;
  }

  .docs-content {
    min-width: 0;
  }

  .docs-content :global(h2) {
    margin-top: 64px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .docs-content :global(h2:first-child) {
    margin-top: 0;
  }

  .breadcrumb {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--text-muted);
    border-bottom: none;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb .current {
    color: var(--text);
  }

  .docs-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 48px;
    padding-bottom: 16px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .docs-content :global(h3) {
    margin-top: 40px;
    margin-bottom: 12px;
  }

  .docs-content :global(p) {
    margin-bottom: 16px;
    color: var(--text);
    line-height: 1.7;
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .docs-content :global(li) {
    margin-bottom: 6px;
    color: var(--text);
    line-height: 1.6;
  }

  .docs-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-surface);
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--accent);
  }

  .docs-content :global(pre) {
    background: var(--bg-raised);
    border: var(--border-weight) solid var(--border);
    padding: 20px 24px;
    margin-bottom: 24px;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .docs-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 0.85rem;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    border: var(--border-weight) solid var(--border);
    padding: 10px 16px;
    text-align: left;
  }

  .docs-content :global(th) {
    background: var(--bg-raised);
    color: var(--text-bright);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
  }

  .docs-content :global(kbd) {
    font-family: var(--font-mono);
    font-size: 0.8em;
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    padding: 2px 8px;
    color: var(--text-bright);
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
      padding-top: 72px;
    }

    .docs-sidebar {
      display: none;
    }
  }
</style>
