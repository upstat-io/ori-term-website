---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import ConsoleChangelog from '../components/ConsoleChangelog.svelte';
import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';

// Load commit data generated by scripts/generate-changelog.sh
const jsonPath = resolve(process.cwd(), 'public', 'changelog.json');
let commits: any[] = [];
if (existsSync(jsonPath)) {
  commits = JSON.parse(readFileSync(jsonPath, 'utf-8'));
}

// Fetch GitHub releases at build time
interface Release {
  tag: string;
  date: string;
  url: string;
  body: string;
  prerelease: boolean;
}

let releases: Release[] = [];
try {
  const res = await fetch(
    'https://api.github.com/repos/upstat-io/ori-term/releases?per_page=30',
    { headers: { 'Accept': 'application/vnd.github.v3+json' } }
  );
  if (res.ok) {
    const data = await res.json();
    const seen = new Set<string>();
    for (const r of data) {
      const tagDate = r.tag_name.match(/(\d{4})(\d{2})(\d{2})/);
      const date = tagDate ? `${tagDate[1]}-${tagDate[2]}-${tagDate[3]}` : r.published_at?.split('T')[0] ?? '';
      if (seen.has(date)) continue;
      seen.add(date);
      releases.push({
        tag: r.tag_name,
        date,
        url: r.html_url,
        body: r.body ?? '',
        prerelease: r.prerelease ?? false,
      });
    }
  }
} catch {
  // Build continues without releases
}
---

<Base title="CHANGELOG — ori-term" description="Development changelog for ori-term, rendered as an interactive console.">
  <Nav client:load />
  <main class="changelog-page">
    <header class="page-header">
      <h1>Changelog</h1>
      <p class="subtitle">Release notes and commit history for ori-term.</p>
    </header>
    <ConsoleChangelog entries={commits} releases={releases} client:load />
  </main>
</Base>

<style>
  .changelog-page {
    padding: 80px 24px 48px;
    max-width: 1248px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 32px;
  }

  .page-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    letter-spacing: 0.05em;
  }

  .subtitle {
    color: var(--text-muted);
    margin-top: 8px;
    font-size: 0.9rem;
  }
</style>
