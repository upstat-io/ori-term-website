---
import Docs from '../../layouts/Docs.astro';

const toc = [
  { id: 'splitting', text: 'Splitting', level: 2 },
  { id: 'navigation', text: 'Navigation', level: 2 },
  { id: 'resizing', text: 'Resizing', level: 2 },
  { id: 'zoom', text: 'Zoom', level: 2 },
  { id: 'floating', text: 'Floating Panes', level: 2 },
  { id: 'history', text: 'Undo / Redo', level: 2 },
  { id: 'closing', text: 'Closing', level: 2 },
