---
import Docs from '../../layouts/Docs.astro';
import { keys } from '../../lib/keybindings';

const toc = [
  { id: 'location', text: 'Config Location', level: 2 },
  { id: 'format', text: 'Format', level: 2 },
  { id: 'hot-reload', text: 'Hot Reload', level: 2 },
  { id: 'font', text: 'Font', level: 2 },
  { id: 'theme', text: 'Theme', level: 2 },
  { id: 'window', text: 'Window', level: 2 },
  { id: 'cursor', text: 'Cursor', level: 2 },
  { id: 'scrollback', text: 'Scrollback', level: 2 },
  { id: 'shell', text: 'Shell', level: 2 },
  { id: 'mouse', text: 'Mouse', level: 2 },
  { id: 'keybindings', text: 'Keybindings', level: 2 },
  { id: 'url-patterns', text: 'URL Patterns', level: 2 },
