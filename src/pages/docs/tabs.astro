---
import Docs from '../../layouts/Docs.astro';
import { keys } from '../../lib/keybindings';

const toc = [
  { id: 'basics', text: 'Basics', level: 2 },
  { id: 'navigation', text: 'Navigation', level: 2 },
  { id: 'drag-drop', text: 'Drag & Drop', level: 2 },
  { id: 'multi-window', text: 'Multi-Window', level: 2 },
];
---

<Docs title="Tabs & Windows" toc={toc}>
  <h2 id="basics">Basics</h2>
  <p>Each tab contains its own independent set of panes. Create and close tabs:</p>
  <ul>
    <li><kbd>{keys.newTab}</kbd> — New tab (inherits working directory)</li>
    <li><kbd>{keys.closeTab}</kbd> — Close the current tab</li>
  </ul>

  <h2 id="navigation">Navigation</h2>
  <ul>
    <li><kbd>{keys.nextTab}</kbd> — Next tab</li>
    <li><kbd>{keys.prevTab}</kbd> — Previous tab</li>
    <li><strong>Click</strong> — Click any tab in the tab bar to switch to it</li>
  </ul>

  <h2 id="drag-drop">Drag & Drop</h2>
  <p>Tabs support Chrome-style drag and drop:</p>
  <ul>
    <li><strong>Reorder</strong> — Drag a tab left or right to change its position</li>
    <li><strong>Tear off</strong> — Drag a tab outside the window to open it in a new window</li>
    <li><strong>Merge</strong> — Drag a tab from one window into another window's tab bar</li>
  </ul>

  <h2 id="multi-window">Multi-Window</h2>
  <p>ori-term supports multiple windows. Drag tabs between them freely.</p>
  <p>Each window gets proper per-monitor DPI handling. Moving a window between monitors with different scale factors triggers a seamless rescale of fonts and UI elements.</p>
</Docs>
