---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import TerminalHero from '../components/TerminalHero.svelte';
import GlitchText from '../components/GlitchText.svelte';
import FeatureGrid from '../components/FeatureGrid.svelte';
import InstallBlock from '../components/InstallBlock.svelte';
import Footer from '../components/Footer.svelte';
---

<Base title="ori-term — GPU-Accelerated Terminal Emulator">
  <Nav client:load />

  <main>
    <section class="hero-header">
      <div class="container">
        <GlitchText
          client:load
          text="ORI-TERM"
          tag="h1"
          speed={30}
        />
        <GlitchText
          client:load
          text="GPU-ACCELERATED TERMINAL EMULATOR"
          tag="h2"
          delay={400}
          speed={25}
        />
        <p class="hero-desc">
          A terminal emulator built from scratch in Rust. GPU-rendered with wgpu.
          Native multiplexing. Persistent sessions. Cross-platform.
        </p>
      </div>
    </section>

    <TerminalHero client:load />

    <section class="pitch" aria-label="Value proposition">
      <div class="container">
        <div class="pitch-grid">
          <div class="pitch-item">
            <span class="pitch-number">01</span>
            <p>Built in Rust. Rendered with wgpu. No Electron. No compromise. Every frame is GPU-composed with damage tracking — only changed cells hit the pipeline.</p>
          </div>
          <div class="pitch-item">
            <span class="pitch-number">02</span>
            <p>Multiplexing is native, not bolted on. Splits, tabs, floating panes, and persistent sessions are first-class primitives. Drop tmux.</p>
          </div>
          <div class="pitch-item">
            <span class="pitch-number">03</span>
            <p>A daemon keeps your sessions alive. GUI crashes, network drops — reconnect and pick up where you left off. Multiple clients, one process tree.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="features-section">
      <div class="container">
        <h2 class="section-label">// SPECS</h2>
      </div>
      <FeatureGrid client:visible />
      <div class="container features-cta">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/features`} class="cta-link">
          ALL FEATURES
          <svg class="cta-arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </section>

    <section class="highlights" aria-label="Highlights">
      <div class="container">
        <h2 class="section-label">// WHY SWITCH</h2>
        <div class="highlight-grid">
          <div class="highlight-block">
            <h3>LIGATURES THAT ACTUALLY WORK</h3>
            <p class="highlight-pain">Alacritty won't add ligature support. Their most-requested issue — open since 2017 — is closed as wontfix.</p>
            <p>ori-term ships HarfBuzz shaping out of the box. Fira Code, JetBrains Mono, Iosevka — ligatures, complex scripts, multi-face fallback chains. No config needed.</p>
          </div>
          <div class="highlight-block">
            <h3>DROP TMUX</h3>
            <p class="highlight-pain">tmux breaks truecolor, mangles escape sequences, fights your clipboard, and demands its own config language. It's a second system bolted onto your terminal.</p>
            <p>ori-term has splits, tabs, floating panes, and sessions built in. One config file, one process, zero compatibility hacks. Your colors stay correct.</p>
          </div>
          <div class="highlight-block">
            <h3>SESSIONS THAT SURVIVE</h3>
            <p class="highlight-pain">SSH drops. GUI crashes. Power blips. Most terminals lose everything — scrollback, layout, working directories. Gone.</p>
            <p>ori-term's daemon keeps sessions alive independently. Crash recovery is automatic. Reconnect from any client and pick up exactly where you left off.</p>
          </div>
          <div class="highlight-block">
            <h3>GPU SPEED WITHOUT THE TRADEOFFS</h3>
            <p class="highlight-pain">Fast terminals strip features to stay fast. Slow terminals add features but lag on large output. Pick two out of three.</p>
            <p>ori-term renders every frame on the GPU via wgpu with damage tracking — only changed cells hit the pipeline. Full features, full speed, no compromise.</p>
          </div>
        </div>
      </div>
    </section>

    <InstallBlock client:visible />
  </main>

  <Footer client:load />
</Base>

<style>
  main {
    padding-top: 56px;
  }

  .hero-header {
    padding: 64px 0 0;
    text-align: center;
  }

  .hero-header :global(h1) {
    font-size: clamp(3rem, 10vw, 7rem);
    letter-spacing: 0.1em;
    line-height: 1;
    color: var(--text-bright);
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 16px;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-header :global(h2) {
    font-size: clamp(0.7rem, 2vw, 1rem);
    color: var(--text-muted);
    letter-spacing: 0.3em;
    margin-top: 16px;
    font-weight: 400;
  }

  .pitch {
    padding: 80px 0;
    border-top: var(--border-weight) solid var(--border);
    border-bottom: var(--border-weight) solid var(--border);
  }

  .pitch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .pitch-item {
    padding: 32px 24px;
    border-right: var(--border-weight) solid var(--border);
  }

  .pitch-item:last-child {
    border-right: none;
  }

  .pitch-number {
    display: block;
    font-size: 0.9rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 16px;
  }

  .pitch-item p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .features-section {
    padding-top: 80px;
    padding-bottom: 80px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .section-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 32px;
    font-weight: 400;
    text-transform: uppercase;
  }

  .features-cta {
    margin-top: 32px;
    text-align: right;
  }

  .cta-link {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    border-bottom: var(--border-weight) solid transparent;
    padding-bottom: 4px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .cta-arrow {
    width: 14px;
    height: 14px;
  }

  .cta-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .highlights {
    padding: 80px 0 120px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  .highlight-block {
    border: var(--border-weight) solid var(--border);
    padding: 40px 32px;
  }

  .highlight-block h3 {
    color: var(--text-bright);
    font-size: 1rem;
    margin-bottom: 16px;
    letter-spacing: 0.1em;
  }

  .highlight-pain {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
    border-left: var(--border-weight) solid var(--border-strong);
    padding-left: 16px;
    margin-bottom: 16px;
    font-style: italic;
  }

  .highlight-block p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .pitch-grid {
      grid-template-columns: 1fr;
    }

    .pitch-item {
      border-right: none;
      border-bottom: var(--border-weight) solid var(--border);
    }

    .pitch-item:last-child {
      border-bottom: none;
    }

    .highlight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
