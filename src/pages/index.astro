---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import TerminalHero from '../components/TerminalHero.svelte';
import GlitchText from '../components/GlitchText.svelte';
import FeatureGrid from '../components/FeatureGrid.svelte';
import InstallBlock from '../components/InstallBlock.svelte';
import Footer from '../components/Footer.svelte';

// Fetch latest release tag at build time
let latestVersion = '';
try {
  const res = await fetch(
    'https://api.github.com/repos/upstat-io/ori-term/releases?per_page=1',
    { headers: { 'Accept': 'application/vnd.github.v3+json' } }
  );
  if (res.ok) {
    const releases = await res.json();
    if (releases.length > 0) {
      // Strip leading 'v' from tag (e.g. "v0.2.0-alpha.20260404" -> "0.2.0-alpha.20260404")
      latestVersion = releases[0].tag_name.replace(/^v/, '');
    }
  }
} catch {
  // Build continues with fallback
}
---

<Base title="ori-term — GPU-Accelerated Terminal Emulator">
  <Nav client:load />

  <main>
    <section class="hero-header">
      <div class="container">
        <GlitchText
          client:load
          text="ORI-TERM"
          tag="h1"
          speed={30}
        />
        <GlitchText
          client:load
          text="GPU-ACCELERATED TERMINAL EMULATOR"
          tag="h2"
          delay={400}
          speed={25}
        />
        <p class="hero-desc">
          A terminal emulator built from scratch in Rust. GPU-rendered with wgpu.
          Native multiplexing. Cross-platform.
        </p>
      </div>
    </section>

    <TerminalHero client:load version={latestVersion} />

    <section class="pitch" aria-label="Value proposition">
      <div class="container">
        <div class="pitch-grid">
          <div class="pitch-item">
            <span class="pitch-number">01</span>
            <p>Built in Rust. Rendered with wgpu. No Electron. No compromise. Every frame is GPU-composed with damage tracking — only changed cells hit the pipeline.</p>
          </div>
          <div class="pitch-item">
            <span class="pitch-number">02</span>
            <p>Multiplexing is native, not bolted on. Splits, tabs, and floating panes are first-class primitives. Drop tmux.</p>
          </div>
          <div class="pitch-item">
            <span class="pitch-number">03</span>
            <p>Cross-platform from day one. Windows, Linux, and macOS are all first-class — no platform is an afterthought. Same features, same quality.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="features-section">
      <div class="container">
        <h2 class="section-label">// SPECS</h2>
      </div>
      <FeatureGrid client:visible />
      <div class="container features-cta">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/features`} class="cta-link">
          ALL FEATURES
          <svg class="cta-arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </section>

    <section class="highlights" aria-label="Highlights">
      <div class="container">
        <h2 class="section-label">// WHY SWITCH</h2>
        <div class="highlight-grid">
          <div class="highlight-block">
            <h3>REAL FONT RENDERING</h3>
            <p class="highlight-pain">Most GPU terminals skip ligature support entirely. Your carefully chosen coding font renders as plain text.</p>
            <p>ori-term ships HarfBuzz shaping. Fira Code, JetBrains Mono, Iosevka — ligatures, complex scripts, multi-face fallback chains. Your font works the way it was designed.</p>
          </div>
          <div class="highlight-block">
            <h3>NO MULTIPLEXER NEEDED</h3>
            <p class="highlight-pain">Terminal multiplexers break truecolor, mangle escape sequences, fight your clipboard, and demand their own config language.</p>
            <p>ori-term has splits, tabs, and floating panes built in. One config file, one process, zero compatibility layers. Your colors stay correct.</p>
          </div>
          <div class="highlight-block">
            <h3>CROSS-PLATFORM, NO ASTERISKS</h3>
            <p class="highlight-pain">Most GPU terminals launch on one platform first, then bolt on the others as an afterthought. Linux-only for years. macOS "experimental". Windows "coming soon".</p>
            <p>ori-term builds and runs on Windows, Linux, and macOS from day one. ConPTY, fontconfig, CoreText, Vulkan, DX12, Metal — each platform gets its native stack. Same features everywhere.</p>
          </div>
          <div class="highlight-block">
            <h3>GPU SPEED, FULL FEATURES</h3>
            <p class="highlight-pain">Fast terminals strip features to stay fast. Feature-rich terminals lag on large output. The tradeoff feels inevitable.</p>
            <p>ori-term renders every frame on the GPU with damage tracking — only changed cells hit the pipeline. Full features at full speed.</p>
          </div>
        </div>
      </div>
    </section>

    <InstallBlock client:visible />

    <section class="other-projects" aria-label="Other projects">
      <div class="container">
        <h2 class="section-label">// FROM THE TEAM</h2>
        <div class="projects-grid">
          <a href="https://upstat.io" target="_blank" rel="noopener" class="project-cell">
            <div class="project-icon">
              <svg viewBox="0 0 33 33" fill="none">
                <path d="M5.39 23.44L3.22 21.27l-.37.37.33.4a29.5 29.5 0 0 1 7.86-4.53c2.15-.74 4.21-1.04 6.02-.87l.05-.52-.52.05c.16 1.81-.14 3.88-.88 6.03a29.5 29.5 0 0 1-4.52 7.86l.4.33.37-.37-2.17-2.17a.52.52 0 0 1 .74-.74l2.17 2.17c.1.1.25.16.39.15a.52.52 0 0 0 .38-.19 31 31 0 0 0 4.71-8.18c.78-2.26 1.1-4.47.93-6.46a.52.52 0 0 0-.47-.47c-2-.18-4.2.13-6.46.9A31 31 0 0 0 2.52 21.24a.52.52 0 0 0 .15.77l2.17 2.17a.52.52 0 0 0 .74-.74Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
                <path d="M27.72 15.25a.5.5 0 0 1-.14.08.52.52 0 0 1-.64-.09l-2.26-1.98-5 2.19a.52.52 0 0 1-.63-.15.52.52 0 0 1-.11-.55l2.73-5.13-2.83 1.21a.4.4 0 0 1-.43-.04.4.4 0 0 1-.22-.46l.33-2.04-1.27-1.12a.4.4 0 0 1-.04-.53.4.4 0 0 1 .08-.11.5.5 0 0 1 .13-.09.52.52 0 0 1 .65.08l1.47 1.29a.4.4 0 0 1 .16.41l-.22 1.38 3.3-1.41a.52.52 0 0 1 .49.09.52.52 0 0 1 .11.55l-2.72 5.11 3.94-1.73a.52.52 0 0 1 .61.07l.03.02 2.54 2.23a.4.4 0 0 1 .08.86.5.5 0 0 1-.12.16Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.15"/>
                <path d="M9.55 23.29L5.18 27.65a.52.52 0 0 0 .74.74l4.37-4.37a.52.52 0 0 0-.74-.74Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
                <path d="M6.4 23.21L1.2 28.41a.52.52 0 0 0 .74.74l5.2-5.2a.52.52 0 0 0-.74-.74Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
                <path d="M10.38 26.3L5.18 31.5a.52.52 0 0 0 .74.74l5.2-5.2a.52.52 0 0 0-.74-.74Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
                <path d="M3.68 29.17L1.2 31.65a.52.52 0 0 0 .74.74l2.48-2.48a.52.52 0 0 0-.74-.74Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
                <path d="M16.11 23.41c3.5-.76 7-2.63 9.91-5.54 3.89-3.9 5.93-8.83 5.93-13.42 0-.82-.07-1.63-.2-2.42l-.05-.32-.32-.05A14.5 14.5 0 0 0 28.95 1.46c-4.59 0-9.52 2.03-13.41 5.92-2.92 2.92-4.79 6.42-5.54 9.92l.89.19c.72-3.32 2.5-6.67 5.3-9.46 3.73-3.73 8.45-5.66 12.77-5.66.77 0 1.53.06 2.27.19l.08-.45-.45.08c.12.74.19 1.5.19 2.27 0 4.32-1.93 9.04-5.66 12.77-2.8 2.8-6.14 4.58-9.46 5.3l.19.89Z" fill="var(--accent)" stroke="var(--accent)" stroke-width="0.3"/>
              </svg>
            </div>
            <span class="project-name">UPSTAT</span>
            <p>Incident response & operational intelligence for DevOps and SREs.</p>
            <span class="project-url">upstat.io</span>
          </a>
          <a href="https://orijs.org" target="_blank" rel="noopener" class="project-cell">
            <div class="project-icon">
              <svg viewBox="0 0 28 28" fill="none">
                <circle cx="14" cy="14" r="12" stroke="var(--accent)" stroke-width="2" fill="none"/>
                <path d="M14 6C10 10 8 16 14 22C20 16 18 10 14 6Z" fill="var(--accent)" opacity="0.7"/>
                <path d="M14 8C12 12 10 16 14 20" stroke="var(--accent)" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <span class="project-name">ORIJS</span>
            <p>NestJS-inspired backend framework for Bun. Provider-based DI, no decorators.</p>
            <span class="project-url">orijs.org</span>
          </a>
          <a href="https://ori-lang.com" target="_blank" rel="noopener" class="project-cell">
            <div class="project-icon">
              <svg viewBox="0 0 32 32" fill="none">
                <defs>
                  <linearGradient id="ori-lang-bg" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#0a1a0a"/>
                    <stop offset="100%" stop-color="#0a2010"/>
                  </linearGradient>
                </defs>
                <rect width="32" height="32" rx="8" fill="url(#ori-lang-bg)"/>
                <path d="M9 9 L17 16 L9 23" stroke="var(--accent)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17 9 L25 16 L17 23" stroke="var(--accent)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="project-name">ORI LANG</span>
            <p>Expression-based language with automatic reference counting. No GC, no borrow checker.</p>
            <span class="project-url">ori-lang.com</span>
          </a>
          <a href="https://warpkit.org" target="_blank" rel="noopener" class="project-cell">
            <div class="project-icon">
              <svg viewBox="2 6 28 20" fill="none">
                <path d="M8 16 Q12 14, 16 14" stroke="var(--accent)" stroke-width="1.5" fill="none" opacity="0.5" stroke-linecap="round"/>
                <path d="M6 16 Q12 16, 18 16" stroke="var(--accent)" stroke-width="1.8" fill="none" opacity="0.7" stroke-linecap="round"/>
                <path d="M8 16 Q12 18, 16 18" stroke="var(--accent)" stroke-width="1.5" fill="none" opacity="0.5" stroke-linecap="round"/>
                <path d="M18 10 L26 16 L18 22 L21 16 Z" fill="var(--accent)"/>
              </svg>
            </div>
            <span class="project-name">WARPKIT</span>
            <p>Svelte 5 SPA framework with state-based routing and pluggable providers.</p>
            <span class="project-url">warpkit.org</span>
          </a>
          <a href="https://cloudlayer.io" target="_blank" rel="noopener" class="project-cell">
            <div class="project-icon">
              <svg viewBox="0 0 40 40" fill="none">
                <path d="M12.3 3.67L4.05 11.14C-1.35 16.03-1.35 23.97 4.05 28.87L12.3 36.33C14.99 38.78 18.54 40 22.08 40C25.63 40 29.17 38.78 31.87 36.33L39.92 29.04C40.03 28.95 40.03 28.79 39.92 28.69L37.22 26.24C37.11 26.15 36.94 26.15 36.83 26.24L28.78 33.53C25.09 36.88 19.08 36.88 15.39 33.53L7.14 26.07C3.45 22.72 3.45 17.28 7.14 13.94L15.39 6.47C19.08 3.13 25.09 3.13 28.78 6.47L36.83 13.76C36.94 13.86 37.11 13.86 37.22 13.76L39.92 11.31C40.03 11.22 40.03 11.06 39.92 10.96L31.87 3.67C29.17 1.22 25.63 0 22.08 0C18.54 0 15 1.22 12.3 3.67" fill="var(--accent)"/>
                <path d="M17.45 10.2L11.46 15.63C11.35 15.72 11.35 15.88 11.46 15.98L14.16 18.43C14.27 18.52 14.44 18.52 14.55 18.43L20.54 13C20.95 12.63 21.5 12.42 22.08 12.42C22.67 12.42 23.22 12.63 23.63 13L29.81 18.6C30.66 19.37 30.66 20.63 29.81 21.4L23.63 27C23.22 27.37 22.67 27.58 22.08 27.58C21.5 27.58 20.95 27.37 20.54 27L14.55 21.57C14.44 21.48 14.27 21.48 14.16 21.57L11.46 24.02C11.35 24.12 11.35 24.28 11.46 24.37L17.45 29.8C18.73 30.96 20.41 31.54 22.08 31.54C23.76 31.54 25.44 30.96 26.72 29.8L32.9 24.2C35.46 21.88 35.46 18.12 32.9 15.8L26.72 10.2C25.44 9.04 23.76 8.46 22.08 8.46C20.41 8.46 18.73 9.04 17.45 10.2" fill="var(--accent)" opacity="0.7"/>
              </svg>
            </div>
            <span class="project-name">CLOUDLAYER</span>
            <p>Document conversion API. Generate pixel-perfect PDFs and images from HTML.</p>
            <span class="project-url">cloudlayer.io</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Base>

<style>
  main {
    padding-top: 56px;
  }

  .hero-header {
    padding: 64px 0 0;
    text-align: center;
  }

  .hero-header :global(h1) {
    font-size: clamp(3rem, 10vw, 7rem);
    letter-spacing: 0.1em;
    line-height: 1;
    color: var(--text-bright);
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 16px;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-header :global(h2) {
    font-size: clamp(0.7rem, 2vw, 1rem);
    color: var(--text-muted);
    letter-spacing: 0.3em;
    margin-top: 16px;
    font-weight: 400;
  }

  .pitch {
    padding: 80px 0;
    border-top: var(--border-weight) solid var(--border);
    border-bottom: var(--border-weight) solid var(--border);
  }

  .pitch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .pitch-item {
    padding: 32px 24px;
    border-right: var(--border-weight) solid var(--border);
  }

  .pitch-item:last-child {
    border-right: none;
  }

  .pitch-number {
    display: block;
    font-size: 0.9rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 16px;
  }

  .pitch-item p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .features-section {
    padding-top: 80px;
    padding-bottom: 80px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .section-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 32px;
    font-weight: 400;
    text-transform: uppercase;
  }

  .features-cta {
    margin-top: 32px;
    text-align: right;
  }

  .cta-link {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    border-bottom: var(--border-weight) solid transparent;
    padding-bottom: 4px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .cta-arrow {
    width: 14px;
    height: 14px;
  }

  .cta-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .highlights {
    padding: 80px 0 120px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  .highlight-block {
    border: var(--border-weight) solid var(--border);
    padding: 40px 32px;
  }

  .highlight-block h3 {
    color: var(--text-bright);
    font-size: 1rem;
    margin-bottom: 16px;
    letter-spacing: 0.1em;
  }

  .highlight-pain {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
    border-left: var(--border-weight) solid var(--border-strong);
    padding-left: 16px;
    margin-bottom: 16px;
    font-style: italic;
  }

  .highlight-block p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .other-projects {
    padding: 80px 0;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .project-cell {
    border: var(--border-weight) solid var(--border);
    padding: 32px 24px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  .project-cell:hover {
    background: var(--bg-surface);
  }

  .project-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: var(--border-weight) solid var(--border);
    margin-bottom: 16px;
  }

  .project-icon svg {
    width: 22px;
    height: 22px;
  }

  .project-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .project-cell p {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .project-url {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .project-cell:hover .project-url {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .pitch-grid {
      grid-template-columns: 1fr;
    }

    .pitch-item {
      border-right: none;
      border-bottom: var(--border-weight) solid var(--border);
    }

    .pitch-item:last-child {
      border-bottom: none;
    }

    .highlight-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
