---
import Feature from '../../layouts/Feature.astro';
import { keys } from '../../lib/keybindings';
---

<Feature
  title="SEARCH"
  subtitle="Plain text and regex search with match highlighting and navigation."
>
  <h2>Search Overlay</h2>
  <p>Press <kbd>{keys.openSearch}</kbd> to open the search bar. Type your query and matches are highlighted across the viewport and scrollback in real time. The search bar shows "N of M" match counts and supports keyboard navigation.</p>

  <h2>Search Modes</h2>
  <ul>
    <li><strong>Plain text</strong> -- Literal substring matching with optional case sensitivity</li>
    <li><strong>Regex</strong> -- Full regular expression support with multiline matching</li>
  </ul>

  <h2>Navigation</h2>
  <ul>
    <li><kbd>{keys.nextMatch}</kbd> / <kbd>{keys.prevMatch}</kbd> -- Next/previous match</li>
    <li><kbd>{keys.closeSearch}</kbd> -- Close search</li>
  </ul>
  <p>The viewport automatically scrolls to center the current match.</p>
</Feature>
