---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.svelte';
import Footer from '../../components/Footer.svelte';
import { keys } from '../../lib/keybindings';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = [
  {
    label: 'CORE',
    features: [
      { title: 'GPU Rendering', href: `${base}/features/gpu-rendering`, desc: 'wgpu with Vulkan + DX12 on Windows, Vulkan on Linux, Metal on macOS. Damage tracking, frame pacing' },
      { title: 'Terminal Emulation', href: `${base}/features/terminal-emulation`, desc: 'Full VTE escape sequences, truecolor, text reflow on resize, configurable scrollback, mouse reporting, Kitty keyboard protocol' },
      { title: 'Fonts & Text', href: `${base}/features/fonts`, desc: 'HarfBuzz shaping, ligatures, complex scripts, multi-face fallback, color emoji, subpixel rendering, OpenType features, text decorations' },
      { title: 'Images', href: `${base}/features/images`, desc: 'Kitty graphics protocol, Sixel, iTerm2 inline images, animated GIF support, GPU compositing' },
    ],
  },
  {
    label: 'MULTIPLEXER',
    features: [
      { title: 'Split Panes', href: `${base}/features/multiplexer`, desc: 'Horizontal and vertical splits, spatial navigation, drag-to-resize dividers, zoom/unzoom, equalize, undo/redo splits' },
      { title: 'Floating Panes', href: `${base}/features/floating-panes`, desc: 'Overlay panes that float, drag, resize, and toggle between floating and tiled layouts with z-ordering' },
      { title: 'Tabs', href: `${base}/features/tabs`, desc: 'Chrome-style tear-off into new windows, drag back in, reorder with animation, hover preview thumbnails, bell indicators' },
      { title: 'Multi-Window', href: `${base}/features/multi-window`, desc: 'Shared GPU across windows, cross-window tab drag and drop, per-window DPI scaling' },
    ],
  },
  {
    label: 'INTERACTION',
    features: [
      { title: 'Keyboard', href: `${base}/features/keyboard`, desc: 'Kitty keyboard protocol, progressive enhancement, IME, dead keys, configurable keybindings' },
      { title: 'Mouse & Selection', href: `${base}/features/mouse-selection`, desc: 'Word, line, and block selection, formatted copy (HTML/RTF), copy-on-select, file drag-and-drop, OSC 52 clipboard' },
      { title: 'Vi Mode', href: `${base}/features/vi-mode`, desc: 'Modal hjkl navigation, word and line motions, inline search (f/F/t/T), bracket matching, visual selection modes, yank' },
      { title: 'Hints & Quick Select', href: `${base}/features/hints`, desc: 'Vimium-style keyboard labels for URLs, file paths, git hashes, IP addresses, emails. Custom regex patterns and actions' },
      { title: 'Search', href: `${base}/features/search`, desc: `Plain text and regex search, <kbd>${keys.openSearch}</kbd> overlay with match count, highlighted matches, keyboard navigation` },
      { title: 'URLs & Hyperlinks', href: `${base}/features/urls`, desc: `Implicit URL detection with hover underline, OSC 8 explicit hyperlinks, <kbd>${keys.openUrl}</kbd> to open, custom URL patterns` },
    ],
  },
  {
    label: 'VISUAL',
    features: [
      { title: 'Themes & Color', href: `${base}/features/themes`, desc: '100+ built-in themes (Catppuccin, Dracula, Nord, Gruvbox, Tokyo Night, and more). TOML files, hot-reload, auto light/dark switching, import from iTerm2/Ghostty/base16' },
      { title: 'Window & Display', href: `${base}/features/window`, desc: 'Frameless window with tab bar as title bar, platform-specific controls, Aero Snap, transparency, HiDPI, smooth scrolling, background images' },
    ],
  },
  {
    label: 'SESSION & REMOTE',
    features: [
      { title: 'Daemon Mode', href: `${base}/features/daemon`, desc: 'Sessions survive after GUI closes. Crash recovery with auto-restore. Multiple clients connect to one daemon' },
      { title: 'Session Persistence', href: `${base}/features/sessions`, desc: 'Auto-save layout every 30 seconds. Scrollback archived to disk. Unlimited scrollback with configurable retention' },
      { title: 'Remote Access', href: `${base}/features/remote`, desc: 'SSH domains with agent forwarding, WSL integration, TCP+TLS connections, reconnection with Mosh-style predictive echo' },
      { title: 'TUI Client', href: `${base}/features/tui-client`, desc: 'Terminal-in-terminal tmux replacement. Prefix key mode, split rendering, mouse support. Attaches to the same daemon sessions' },
    ],
  },
  {
    label: 'SYSTEM',
    features: [
      { title: 'Shell Integration', href: `${base}/features/shell-integration`, desc: 'Automatic shell detection (bash, zsh, fish, PowerShell), CWD tracking, semantic zones, prompt detection, desktop notifications' },
      { title: 'Configuration', href: `${base}/features/configuration`, desc: 'TOML config with hot-reload. Configurable keybindings, font size zoom, sensible defaults, per-platform paths' },
      { title: 'Platform Support', href: `${base}/features/platform`, desc: 'Windows (ConPTY, DirectWrite, Aero Snap), Linux (X11 + Wayland, fontconfig), macOS (CoreText, Metal). All first-class' },
      { title: 'Scripting', href: `${base}/features/scripting`, desc: 'Lua event hooks, custom commands, full API access. WGSL post-processing shaders (CRT, bloom, scanlines)' },
      { title: 'Power Features', href: `${base}/features/power-features`, desc: 'Command palette, Quake-style quick terminal, smart paste protection, undo close tab, desktop notifications, taskbar progress' },
    ],
  },
];
---

<Base title="Features — ori-term">
  <Nav client:load />

  <main>
    <header class="page-header">
      <div class="container">
        <h1>FEATURES</h1>
        <h2 class="page-subtitle">EVERYTHING ORI-TERM CAN DO</h2>
      </div>
    </header>

    {categories.map((cat) => (
      <section class="category">
        <div class="container">
          <h3 class="category-label">// {cat.label}</h3>
          <div class="feature-list">
            {cat.features.map((f) => (
              <a href={f.href} class="feature-row">
                <span class="feature-title">{f.title}</span>
                <span class="feature-desc" set:html={f.desc} />
                <svg class="feature-arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}
  </main>

  <Footer client:load />
</Base>

<style>
  main {
    padding-top: 56px;
  }

  .page-header {
    padding: 80px 0 64px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: 0.1em;
    line-height: 1;
  }

  .page-subtitle {
    font-size: clamp(0.65rem, 1.5vw, 0.85rem);
    color: var(--text-muted);
    letter-spacing: 0.25em;
    margin-top: 16px;
    font-weight: 400;
  }

  .category {
    border-bottom: var(--border-weight) solid var(--border);
    padding: 48px 0;
  }

  .category-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 24px;
    font-weight: 400;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 24px;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
  }

  .feature-row:last-child {
    border-bottom: none;
  }

  .feature-row:hover {
    background: var(--bg-raised);
    padding-left: 16px;
    padding-right: 16px;
    margin-left: -16px;
    margin-right: -16px;
  }

  .feature-row:hover .feature-title {
    color: var(--accent);
  }

  .feature-row:hover .feature-arrow {
    color: var(--accent);
  }

  .feature-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text-bright);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feature-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .feature-arrow {
    width: 14px;
    height: 14px;
    color: var(--border-strong);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .feature-row {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }

    .feature-desc {
      grid-column: 1;
      grid-row: 2;
    }

    .feature-arrow {
      grid-row: 1;
    }
  }
</style>
