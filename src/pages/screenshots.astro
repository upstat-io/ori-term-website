---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';

const shots = [
  { src: '/screenshots/multiplexer.png', label: 'MULTIPLEXER', desc: 'Splits, tabs, and floating panes' },
  { src: '/screenshots/themes.png', label: 'THEMES', desc: 'Custom color schemes with hot-reload' },
  { src: '/screenshots/images.png', label: 'IMAGES', desc: 'Kitty graphics and Sixel inline images' },
  { src: '/screenshots/fonts.png', label: 'FONTS', desc: 'Ligatures, emoji, and fallback chains' },
  { src: '/screenshots/search.png', label: 'SEARCH', desc: 'Regex search with match highlighting' },
  { src: '/screenshots/mark-mode.png', label: 'MARK MODE', desc: 'Vi-style keyboard navigation' },
];
---

<Base title="Screenshots — ori-term">
  <Nav client:load />

  <main>
    <header class="page-header">
      <div class="container">
        <h1>SCREENSHOTS</h1>
        <p class="page-desc">The real terminal. No animations, no demos — just ori-term.</p>
      </div>
    </header>

    <section class="gallery">
      <div class="container">
        {shots.map((shot, i) => (
          <figure class="shot" style={`--i: ${i}`}>
            <div class="shot-frame">
              <img
                src={shot.src}
                alt={`ori-term ${shot.label.toLowerCase()} screenshot`}
                loading={i < 2 ? 'eager' : 'lazy'}
                onerror="this.parentElement.classList.add('missing')"
              />
              <div class="shot-placeholder">
                <span>// SCREENSHOT PENDING</span>
              </div>
            </div>
            <figcaption>
              <span class="shot-label">{shot.label}</span>
              <span class="shot-desc">{shot.desc}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>

  <Footer client:load />
</Base>

<style>
  main {
    padding-top: 56px;
  }

  .page-header {
    padding: 80px 0 64px;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: 0.1em;
    line-height: 1;
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 16px;
  }

  .gallery {
    padding: 64px 0 120px;
  }

  .gallery .container {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .shot {
    margin: 0;
  }

  .shot-frame {
    position: relative;
    border: var(--border-weight) solid var(--border-strong);
    background: var(--bg);
    overflow: hidden;
  }

  .shot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .shot-placeholder {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  .shot-frame.missing .shot-placeholder {
    display: flex;
  }

  .shot-frame.missing img {
    display: none;
  }

  .shot-frame.missing {
    min-height: 300px;
    border-style: dashed;
  }

  figcaption {
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding: 16px 0 0;
  }

  .shot-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: 0.15em;
  }

  .shot-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .gallery .container {
      gap: 48px;
    }

    figcaption {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
