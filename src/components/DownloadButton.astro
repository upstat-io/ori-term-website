---
interface Props {
  href: string;
  label: string;
  size?: string;
  releasesUrl?: string;
}

const { href, label, size, releasesUrl = 'https://github.com/upstat-io/ori-term/releases' } = Astro.props;
---

<div class="dl-row">
  <a class="dl-main" href={href} download>
    <span class="dl-icon">&#8595;</span>
    <span class="dl-label">{label}</span>
    {size && <span class="dl-size">({size})</span>}
  </a>
  <a class="dl-gh" href={releasesUrl} aria-label="GitHub Releases">
    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
  </a>
</div>

<style>
  .dl-row {
    display: flex;
    margin-top: 20px;
    border: var(--border-weight) solid var(--border-strong);
  }

  .dl-main {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    padding: 10px 20px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--text);
    background: var(--bg-raised);
    text-decoration: none;
    border-bottom: none;
    transition: all 0.15s;
  }

  .dl-main:hover {
    color: var(--text-bright);
    background: var(--bg-surface);
    border-bottom-color: var(--text-bright);
  }

  .dl-icon {
    font-size: 1.1em;
  }

  .dl-label {
    flex: 1;
  }

  .dl-size {
    font-size: 0.85em;
    color: var(--text-muted);
  }

  .dl-gh {
    display: flex;
    align-items: center;
    padding: 0 16px;
    color: var(--text-muted);
    background: var(--bg-raised);
    border: none;
    border-left: var(--border-weight) solid var(--border-strong);
    text-decoration: none;
    transition: all 0.15s;
  }

  .dl-gh:hover {
    color: var(--text-bright);
    background: var(--bg-surface);
    border-bottom-color: var(--text-bright);
    border-left: var(--border-weight) solid var(--border-strong);
  }

  .dl-gh svg {
    width: 18px;
    height: 18px;
  }
</style>
